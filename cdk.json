{
  "app": "npx ts-node --prefer-ts-exts bin/fleet.ts",
  "watch": {
    "include": ["bin/**", "lib/**", "config/**"],
    "exclude": ["README.md", "cdk.*.json", "**/*.d.ts", "**/*.js", "tsconfig.json", "package*.json", "node_modules"]
  },
  "context": {
    "configFile": "config/platform.yaml",
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": ["aws"],
    "@aws-cdk/aws-ec2:restrictDefaultSecurityGroup": true,
    "@aws-cdk/aws-eks:nodegroupNameAttribute": true,
    "@aws-cdk/aws-ecr:fullEcrRepoLifecyclePolicy": true,
    "@aws-cdk/customresources:installLatestAwsSdkDefault": false
  }
}
